# local: use local OpenCV/canvas logic plus local mock route intent.
# remote: keep local corner detection/perspective correction, call API for map analysis and route intent.
VITE_FLOOR_ROUTE_BACKEND_MODE=local

# Required only when VITE_FLOOR_ROUTE_BACKEND_MODE=remote.
VITE_FLOOR_ROUTE_API_BASE_URL=http://localhost:8000

# Optional bearer token for development/demo API access. Do not put production secrets in frontend env files.
VITE_FLOOR_ROUTE_API_TOKEN=
