# local: use local OpenCV/canvas logic plus local mock route intent.
# remote: keep local corner detection/perspective correction, call API for map analysis and route intent.
VITE_FLOOR_ROUTE_BACKEND_MODE=local

# Required only when VITE_FLOOR_ROUTE_BACKEND_MODE=remote.
VITE_FLOOR_ROUTE_API_BASE_URL=http://localhost:8000

# Optional bearer token for development/demo API access. Do not put production secrets in frontend env files.
VITE_FLOOR_ROUTE_API_TOKEN=

# Shared OpenAI-compatible model config. Text/vision-specific config below falls back to these values.
# Frontend env variables are visible to app users, so only use development/demo keys here.
VITE_FLOOR_ROUTE_MODEL_BASE_URL=
VITE_FLOOR_ROUTE_MODEL_API_KEY=
VITE_FLOOR_ROUTE_MODEL_NAME=

# mock: use the built-in regex/mock recognizer.
# text-model: use the OpenAI-compatible text model below. Missing model config will fail instead of falling back.
VITE_FLOOR_ROUTE_INTENT_RECOGNITION_MODE=mock

# Optional overrides for intent recognition. Empty values use VITE_FLOOR_ROUTE_MODEL_*.
VITE_FLOOR_ROUTE_TEXT_MODEL_BASE_URL=
VITE_FLOOR_ROUTE_TEXT_MODEL_API_KEY=
VITE_FLOOR_ROUTE_TEXT_MODEL_NAME=

# mock: skip image-model analysis and show the built-in prompt.
# vision-model: use the OpenAI-compatible image/vision model below. Missing model config will fail instead of falling back.
VITE_FLOOR_ROUTE_FLOOR_PLAN_ANALYSIS_MODE=mock

# Optional overrides for floor-plan image analysis. Empty values use VITE_FLOOR_ROUTE_MODEL_*.
VITE_FLOOR_ROUTE_VISION_MODEL_BASE_URL=
VITE_FLOOR_ROUTE_VISION_MODEL_API_KEY=
VITE_FLOOR_ROUTE_VISION_MODEL_NAME=
